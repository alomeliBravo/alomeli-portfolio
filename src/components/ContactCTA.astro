---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import Icon from './Icon.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<aside>
	<div class="cta-content">
		<h2>{t('cta.title')}</h2>
		<p>{t('cta.desc')}</p>
	</div>

	<div class="contact-cards">
		<a href="mailto:alomelibravo@gmail.com" class="contact-card">
			<span class="card-icon">
				<Icon icon="paper-plane-tilt" size="2rem" />
			</span>
			<span class="card-label">{t('cta.email')}</span>
			<span class="card-value">alomelibravo@gmail.com</span>
		</a>

		<a href="tel:+526691176919" class="contact-card">
			<span class="card-icon">
				<Icon icon="phone" size="2rem" />
			</span>
			<span class="card-label">{t('cta.phone')}</span>
			<span class="card-value">+52 669 117 6919</span>
		</a>

		<a href="https://www.linkedin.com/in/angel-daniel-lomelí-bravo-3a5648327/" target="_blank" rel="noopener noreferrer" class="contact-card">
			<span class="card-icon">
				<Icon icon="linkedin-logo" size="2rem" />
			</span>
			<span class="card-label">LinkedIn</span>
		</a>
	</div>
</aside>

<style>
	aside {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3rem;
		border-top: 1px solid var(--gray-800);
		padding: 4rem 1.5rem;
		text-align: center;
	}

	.cta-content {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	h2 {
		font-size: var(--text-2xl);
		color: var(--gray-0);
	}

	p {
		font-size: var(--text-md);
		color: var(--gray-400);
		max-width: 44ch;
		line-height: 1.7;
		margin-inline: auto;
	}

	/* ─── Cards ──────────────────────────────────────────────────────── */
	.contact-cards {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1rem;
		width: 100%;
	}

	.contact-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.75rem;
		padding: 1.75rem 1.5rem;
		border-radius: 1rem;
		border: 1px solid var(--gray-800);
		background: var(--gray-999_40);
		text-decoration: none;
		min-width: 180px;
		flex: 1;
		max-width: 220px;
		transition: border-color var(--theme-transition), background var(--theme-transition), transform 0.2s ease;
	}

	.contact-card:hover {
		border-color: var(--accent-regular);
		background: var(--accent-overlay);
		transform: translateY(-3px);
	}

	.card-icon {
		color: var(--accent-regular);
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 0.25rem;
	}

	.card-label {
		font-size: var(--text-xs, 0.7rem);
		font-weight: 700;
		color: var(--gray-400);
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.card-value {
		font-size: var(--text-sm);
		color: var(--gray-300);
		text-align: center;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		max-width: 100%;
	}

	.contact-card:hover .card-icon {
		color: var(--accent-light);
	}

	.contact-card:hover .card-value {
		color: var(--gray-100);
	}

	@media (min-width: 50em) {
		aside {
			padding: 5rem;
		}

		.contact-cards {
			flex-wrap: nowrap;
			max-width: 720px;
		}

		.contact-card {
			flex: 1;
			max-width: none;
		}
	}
</style>
