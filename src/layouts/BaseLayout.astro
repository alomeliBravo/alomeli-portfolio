---
import { getLangFromUrl } from '../i18n/utils';
import Footer from '../components/Footer.astro';
import MainHead from '../components/MainHead.astro';
import Nav from '../components/Nav.astro';

interface Props {
	title?: string | undefined;
	description?: string | undefined;
}

const { title, description } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const b = import.meta.env.BASE_URL;
const bgVars = [
	`--_bg-noise:url('${b}assets/backgrounds/noise.png')`,
	`--_bg-main-light-800:url('${b}assets/backgrounds/bg-main-light-800w.jpg')`,
	`--_bg-main-dark-800:url('${b}assets/backgrounds/bg-main-dark-800w.jpg')`,
	`--_bg-curves-light:url('${b}assets/backgrounds/bg-main-light.svg')`,
	`--_bg-curves-dark:url('${b}assets/backgrounds/bg-main-dark.svg')`,
	`--_bg-subtle1-light-800:url('${b}assets/backgrounds/bg-subtle-1-light-800w.jpg')`,
	`--_bg-subtle2-light-800:url('${b}assets/backgrounds/bg-subtle-2-light-800w.jpg')`,
	`--_bg-footer-light-800:url('${b}assets/backgrounds/bg-footer-light-800w.jpg')`,
	`--_bg-subtle1-dark-800:url('${b}assets/backgrounds/bg-subtle-1-dark-800w.jpg')`,
	`--_bg-subtle2-dark-800:url('${b}assets/backgrounds/bg-subtle-2-dark-800w.jpg')`,
	`--_bg-footer-dark-800:url('${b}assets/backgrounds/bg-footer-dark-800w.jpg')`,
	`--_bg-main-light-1440:url('${b}assets/backgrounds/bg-main-light-1440w.jpg')`,
	`--_bg-main-dark-1440:url('${b}assets/backgrounds/bg-main-dark-1440w.jpg')`,
	`--_bg-subtle1-light-1440:url('${b}assets/backgrounds/bg-subtle-1-light-1440w.jpg')`,
	`--_bg-subtle2-light-1440:url('${b}assets/backgrounds/bg-subtle-2-light-1440w.jpg')`,
	`--_bg-footer-light-1440:url('${b}assets/backgrounds/bg-footer-light-1440w.jpg')`,
	`--_bg-subtle1-dark-1440:url('${b}assets/backgrounds/bg-subtle-1-dark-1440w.jpg')`,
	`--_bg-subtle2-dark-1440:url('${b}assets/backgrounds/bg-subtle-2-dark-1440w.jpg')`,
	`--_bg-footer-dark-1440:url('${b}assets/backgrounds/bg-footer-dark-1440w.jpg')`,
].join(';');
---

<html lang={lang} style={bgVars}>
	<head>
		<MainHead title={title} description={description} />
	</head>
	<body>
		<div class="stack backgrounds">
			<Nav />
			<slot />
			<Footer />
		</div>

		<script>
			// Add "loaded" class once the document has completely loaded.
			addEventListener('load', () => document.documentElement.classList.add('loaded'));
		</script>

		<style>
			:root {
				--_placeholder-bg: linear-gradient(transparent, transparent);
				--bg-image-main: var(--_bg-main-light-800);
				--bg-image-main-curves: var(--_bg-curves-light);
				--bg-image-subtle-1: var(--_placeholder-bg);
				--bg-image-subtle-2: var(--_placeholder-bg);
				--bg-image-footer: var(--_placeholder-bg);
				--bg-svg-blend-mode: overlay;
				--bg-blend-mode: darken;
				--bg-image-aspect-ratio: 2.25;
				--bg-scale: 1.68;
				--bg-aspect-ratio: calc(var(--bg-image-aspect-ratio) / var(--bg-scale));
				--bg-gradient-size: calc(var(--bg-scale) * 100%);
			}

			:root.theme-dark {
				--bg-image-main: var(--_bg-main-dark-800);
				--bg-image-main-curves: var(--_bg-curves-dark);
				--bg-svg-blend-mode: darken;
				--bg-blend-mode: lighten;
			}

			/* These backgrounds are displayed below the fold, so we lazy load them
			   once the `.loaded` class has been set.  */
			:root.loaded {
				--bg-image-subtle-1: var(--_bg-subtle1-light-800);
				--bg-image-subtle-2: var(--_bg-subtle2-light-800);
				--bg-image-footer: var(--_bg-footer-light-800);
			}
			:root.loaded.theme-dark {
				--bg-image-subtle-1: var(--_bg-subtle1-dark-800);
				--bg-image-subtle-2: var(--_bg-subtle2-dark-800);
				--bg-image-footer: var(--_bg-footer-dark-800);
			}

			@media (min-width: 50em) {
				:root {
					--bg-scale: 1;
					--bg-image-main: var(--_bg-main-light-1440);
				}
				:root.theme-dark {
					--bg-image-main: var(--_bg-main-dark-1440);
				}

				:root.loaded {
					--bg-image-subtle-1: var(--_bg-subtle1-light-1440);
					--bg-image-subtle-2: var(--_bg-subtle2-light-1440);
					--bg-image-footer: var(--_bg-footer-light-1440);
				}
				:root.loaded.theme-dark {
					--bg-image-subtle-1: var(--_bg-subtle1-dark-1440);
					--bg-image-subtle-2: var(--_bg-subtle2-dark-1440);
					--bg-image-footer: var(--_bg-footer-dark-1440);
				}
			}

			.backgrounds {
				min-height: 100%;
				isolation: isolate;
				background:
					/*noise*/
					var(--_bg-noise) top center/220px repeat,
					/*footer*/ var(--bg-image-footer) bottom center/var(--bg-gradient-size) no-repeat,
					/*header1*/ var(--bg-image-main-curves) top center/var(--bg-gradient-size) no-repeat,
					/*header2*/ var(--bg-image-main) top center/var(--bg-gradient-size) no-repeat,
					/*base*/ var(--gray-999);
				background-blend-mode: /*noise*/
					overlay,
					/*footer*/ var(--bg-blend-mode),
					/*header1*/ var(--bg-svg-blend-mode),
					/*header2*/ normal,
					/*base*/ normal;
			}
			@media (forced-colors: active) {
				/* Deactivate custom backgrounds for high contrast users. */
				.backgrounds {
					background: none;
					background-blend-mode: none;
					--bg-gradient-size: none;
				}
			}
		</style>
	</body>
</html>
